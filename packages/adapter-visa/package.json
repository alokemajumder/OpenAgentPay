{
  "name": "@openagentpay/adapter-visa",
  "version": "0.1.0",
  "description": "Visa Intelligent Commerce adapter for OpenAgentPay — Visa MCP and AgentCard virtual debit card support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openagentpay",
    "payment",
    "visa",
    "agentcard",
    "mcp",
    "ai-agents"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAgentPay/OpenAgentPay",
    "directory": "packages/adapter-visa"
  },
  "dependencies": {
    "@openagentpay/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
