{
  "name": "@openagentpay/otel-exporter",
  "version": "0.1.0",
  "description": "OpenTelemetry exporter for OpenAgentPay — export agent payment events as OTel spans and metrics",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openagentpay/core": "workspace:*"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agents",
    "payments",
    "opentelemetry",
    "otel",
    "tracing",
    "metrics",
    "observability",
    "402",
    "x402"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openagentpay/openagentpay",
    "directory": "packages/otel-exporter"
  }
}
