{
  "name": "@openagentpay/router",
  "version": "0.1.0",
  "description": "Intelligent payment routing engine for OpenAgentPay — smart adapter selection based on cost, success rate, latency, and policy constraints",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openagentpay/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agents",
    "payments",
    "routing",
    "smart-router",
    "payment-orchestration",
    "failover",
    "cascade"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openagentpay/openagentpay",
    "directory": "packages/router"
  }
}
