{
  "name": "@openagentpay/server-hono",
  "version": "0.1.0",
  "description": "Hono paywall middleware for OpenAgentPay — accept AI agent payments with one line of middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openagentpay",
    "ai-agents",
    "payments",
    "hono",
    "middleware",
    "paywall",
    "402",
    "x402"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@openagentpay/core": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "hono": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
